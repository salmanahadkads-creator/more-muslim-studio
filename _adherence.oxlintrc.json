{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/media/**",
              "deck-stage.js",
              "screens.jsx",
              "tweaks-panel.jsx",
              "ui_kits/slides/**",
              "ui_kits/social/**",
              "ui_kits/website/**",
              "uploads/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:ABC Marist))/i]",
        "message": "Font not provided by the design system. Available: ABC Marist."
      },
      {
        "selector": "JSXOpeningElement[name.name='AudioBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|episode|progress|duration|playing|onToggle|onSeek|key|ref|className|style|children)$/]",
        "message": "<AudioBar> doesn't accept that prop. Declared props: title, episode, progress, duration, playing, onToggle, onSeek."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|name|size|ring|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: src, name, size, ring."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|as|fullWidth|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, as, fullWidth."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|solid|outline|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'solid' | 'outline' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='as'] > Literal[value!=/^(?:button|a)$/]",
        "message": "<Button> as must be one of 'button' | 'a'."
      },
      {
        "selector": "JSXOpeningElement[name.name='EpisodeCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:date|number|season|duration|title|description|image|mobile|onPlay|onTranscript|key|ref|className|style|children)$/]",
        "message": "<EpisodeCard> doesn't accept that prop. Declared props: date, number, season, duration, title, description, image, mobile, onPlay, onTranscript."
      },
      {
        "selector": "JSXOpeningElement[name.name='EyebrowLabel'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|as|key|ref|className|style|children)$/]",
        "message": "<EyebrowLabel> doesn't accept that prop. Declared props: tone, as."
      },
      {
        "selector": "JSXOpeningElement[name.name='EyebrowLabel'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:accent|primary|secondary|muted)$/]",
        "message": "<EyebrowLabel> tone must be one of 'accent' | 'primary' | 'secondary' | 'muted'."
      },
      {
        "selector": "JSXOpeningElement[name.name='PatternTileMeta'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|ground|ink|weight|key|ref|className|style|children)$/]",
        "message": "<PatternTileMeta> doesn't accept that prop. Declared props: id, ground, ink, weight."
      },
      {
        "selector": "JSXOpeningElement[name.name='PatternTileMeta'] > JSXAttribute[name.name='weight'] > Literal[value!=/^(?:solid|line|fine|duo)$/]",
        "message": "<PatternTileMeta> weight must be one of 'solid' | 'line' | 'fine' | 'duo'."
      },
      {
        "selector": "JSXOpeningElement[name.name='PlayButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:playing|size|label|key|ref|className|style|children)$/]",
        "message": "<PlayButton> doesn't accept that prop. Declared props: playing, size, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='PullQuote'] > JSXAttribute > JSXIdentifier[name!=/^(?:cite|marks|align|size|key|ref|className|style|children)$/]",
        "message": "<PullQuote> doesn't accept that prop. Declared props: cite, marks, align, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='PullQuote'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:left|center)$/]",
        "message": "<PullQuote> align must be one of 'left' | 'center'."
      },
      {
        "selector": "JSXOpeningElement[name.name='PullQuote'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:md|lg|xl)$/]",
        "message": "<PullQuote> size must be one of 'md' | 'lg' | 'xl'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Symbol'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|color|title|key|ref|className|style|children)$/]",
        "message": "<Symbol> doesn't accept that prop. Declared props: size, color, title."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: variant."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:outline|filled|ivory|mist)$/]",
        "message": "<Tag> variant must be one of 'outline' | 'filled' | 'ivory' | 'mist'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
